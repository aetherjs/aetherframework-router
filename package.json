  "repository": {
    "type": "git",
    "url": "https://github.com/aetherjs/aetherframework-router.git"
  },
  "bugs": {
    "url": "https://github.com/aetherjs/aetherframework-router/issues"
  },
  "homepage": "https://github.com/aetherjs/aetherframework-router/blob/main/README.md",
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "autocannon": "^7.12.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
